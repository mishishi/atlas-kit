# ─── Atlas Kit · 图鉴社 ──────────────────────────────────────────────
# https://help.github.com/articles/ignoring-files/

# ─── Node / npm ───────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Next.js ─────────────────────────────────────────────────────────
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# ─── Testing ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Env / secrets ───────────────────────────────────────────────────
# Real env files (含 API key) 永远不入仓; 复制 .env.local.example 改
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ─── Atlas Kit runtime data (不入仓 by default, 用 -f 强制 add 初始 60 张) ─
# 注释:
#   早期阶段 (60 张 placeholder card) 把所有 *.png / *.webp 强制 add 进了 git
#   (`git add -f public/cards/*.{png,webp}`), 这样 Vercel deploy 才能 serve 这些
#   图片. 后续 wizard 生成的新图应该照样走 -f 路径, 否则 Vercel 上看不到.
#   真正的"用户内容"应该迁去外部 CDN, 不要把整个 public/cards 当 git binary
#   blob 用 (clone 慢 + diff 难).
# 例外 (依然忽略, 不强制 add):
public/cards/sample-*.png
# 调试用的临时 json / log 散落在根
*.tmp-*.json
.tmp-*.json
/tmp/

# ─── Design reference (设计样图, 留在本地不入仓) ────────────────────
golden_optimized_*.png
golden_optimized_*.jpeg
minimax_golden_*.jpeg
minimax_golden_*.png

# ─── Dev / runtime logs ──────────────────────────────────────────────
dev.log
dev-err.log
*.log

# ─── Editor / OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── Vercel ──────────────────────────────────────────────────────────
.vercel

# ─── Cache / misc ────────────────────────────────────────────────────
.cache/
.eslintcache
.turbo
