# ====================================================
# Atlas Kit — Environment Variables (EXAMPLE / TEMPLATE)
# ====================================================
# Copy this file to `.env.local` and fill in real values.
# DO NOT commit `.env.local` to git (it's in .gitignore).
# ====================================================

# Public site URL — used by sitemap, robots, OG image, metadataBase.
#   Dev:    http://localhost:3000
#   Prod:   https://atlas-kit.vercel.app  (or your real domain)
SITE_URL=http://localhost:3000

# Image generation provider:
#   "matrix"   — mavis CLI (recommended for Chinese text rendering quality)
#   "minimax"  — direct MiniMax HTTP API (works anywhere but worse Chinese rendering)
#   "hailuo"   — alias for minimax
#   "openai"   — DALL-E
IMAGE_PROVIDER=matrix

# MiniMax API key — required when IMAGE_PROVIDER=minimax
# Get yours at: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=your_key_here

# OpenAI API key — only required if IMAGE_PROVIDER=openai
# OPENAI_API_KEY=your_key_here

# Mavis daemon HTTP endpoint — used by /api/generate to call matrix MCP tools.
#   Dev:    http://127.0.0.1:15321  (default, daemon port)
#   Prod:   leave default unless you deploy daemon to a different host
# MAVIS_DAEMON_URL=http://127.0.0.1:15321

# Optional: override mavis binary path (only used by IMAGE_PROVIDER=matrix, no
# longer needed in current code — we call the daemon HTTP API directly)
# MAVIS_BIN_PATH=C:\Users\zrb03\.mavis\bin\mavis.cmd
